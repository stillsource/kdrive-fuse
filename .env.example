# kdrive-fuse / kdrive — environment configuration (example).
#
# Copy this file to `.env`, fill in your values, and just run a binary from the
# same directory — both auto-load `.env` from the working directory:
#
#   cp .env.example .env
#   kdrive-fuse          (or: kdrive sync)
#
# Load a file from another path with KDRIVE_ENV_FILE=/path/to/env.
# Real environment variables always WIN over the file, so an explicit
# `KDRIVE_X=… kdrive …` or systemd `EnvironmentFile=` still overrides it.
#
# IMPORTANT: put comments on their OWN line. A value is taken literally —
# everything after `=` — so a trailing `# comment` becomes part of the value
# (e.g. `KDRIVE_DISK_CACHE_MAX_GB=2  # budget` parses the size as "2  # budget").
#
# `.env` is gitignored — never commit it (it holds your API token).
# For the systemd user service, keep pointing `EnvironmentFile=` at your
# filled-in copy (e.g. ~/.config/kdrive-fuse/env).

# --- Required (both binaries) ---
# kDrive API token (keep secret)
KDRIVE_API_TOKEN=
# numeric drive id, e.g. 1234567
KDRIVE_DRIVE_ID=

# --- Required (kdrive-fuse daemon only) ---
# mount point, e.g. /home/you/kDrive-vfs
KDRIVE_MOUNT=

# --- Optional (defaults shown) ---
# mount/sync a subfolder instead of the drive root
KDRIVE_ROOT_FOLDER_ID=1
# directory-listing cache TTL (seconds)
KDRIVE_CACHE_TTL_SECONDS=30
# disk cache directory (default: ~/.cache/kdrive-fuse)
KDRIVE_DISK_CACHE_DIR=
# disk cache budget (GB)
KDRIVE_DISK_CACHE_MAX_GB=2
# concurrent listings when `kdrive search` walks the tree
KDRIVE_WALK_PARALLELISM=8
# mount read-only: reject all writes with EROFS (safe for shared/audited drives)
# KDRIVE_READONLY=1
# log format: text (default, human-readable for journalctl) or json (jq-friendly)
# KDRIVE_LOG_FORMAT=text
# serve a Prometheus /metrics side-car on this addr (off by default; daemon only)
# KDRIVE_METRICS_ADDR=:9090
# override the API host (testing only)
# KDRIVE_BASE_URL=
# override the upload host (testing only)
# KDRIVE_UPLOAD_BASE_URL=
