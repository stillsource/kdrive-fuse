# kdrive-fuse / kdrive — environment configuration (example).
#
# Copy this file to `.env`, fill in your values, and just run a binary from the
# same directory — both auto-load `.env` from the working directory:
#
#   cp .env.example .env
#   kdrive-fuse          # or: kdrive sync
#
# Load a file from another path with KDRIVE_ENV_FILE=/path/to/env.
# Real environment variables always WIN over the file, so an explicit
# `KDRIVE_X=… kdrive …` or systemd `EnvironmentFile=` still overrides it.
#
# `.env` is gitignored — never commit it (it holds your API token).
# For the systemd user service, keep pointing `EnvironmentFile=` at your
# filled-in copy (e.g. ~/.config/kdrive-fuse/env).

# --- Required (both binaries) ---
KDRIVE_API_TOKEN=            # kDrive API token (keep secret)
KDRIVE_DRIVE_ID=             # numeric drive id, e.g. 1234567

# --- Required (kdrive-fuse daemon only) ---
KDRIVE_MOUNT=                # mount point, e.g. /home/you/kDrive-vfs

# --- Optional (defaults shown) ---
KDRIVE_ROOT_FOLDER_ID=1          # mount/sync a subfolder instead of the drive root
KDRIVE_CACHE_TTL_SECONDS=30      # directory-listing cache TTL
KDRIVE_DISK_CACHE_DIR=           # default: ~/.cache/kdrive-fuse
KDRIVE_DISK_CACHE_MAX_GB=2       # disk cache budget (GB)
# KDRIVE_READONLY=1              # mount read-only: reject all writes with EROFS (safe for shared/audited drives)
# KDRIVE_LOG_FORMAT=text         # log format: text (default, human-readable for journalctl) or json (jq-friendly structured logs)
# KDRIVE_METRICS_ADDR=:9090      # serve a Prometheus /metrics side-car on this addr (off by default)
# KDRIVE_BASE_URL=               # override the API host (testing only)
# KDRIVE_UPLOAD_BASE_URL=        # override the upload host (testing only)
